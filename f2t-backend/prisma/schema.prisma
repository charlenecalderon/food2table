// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Generate a typescypt/javascrypt client to import in Node.js
generator client {
  // Use the prisma client for JavaScript and Typescript
  provider = "prisma-client-js"
}

// Connection to the database with PostgreSQL
datasource db {
  // The type of the database
  provider = "postgresql"
}

//enum for days of the week
enum Day {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  NONE
}

// Define the roles the users can have
enum Role {
  // Role for general users
  BUYER
  USER
  // Role to manage the website
  ADMIN
}

// Define the status of the order
enum OrderStatus {
  // Order is created and being updated with items
  CART
  // Order is reserved and waiting for user to place the order
  RESERVED
  // Order is finalized and ready to be processed
  PLACED
  // Buyer has paid in person and the seller provided the products to the buyer
  COMPLETED
  // Order is cancelled by the buyer or seller
  CANCELLED
}

// Model (data table) to store login and role information
model User {
  // Unique ID for each user
  id String @id @default(cuid())
  // Unique email address
  email String @unique
  // Hashed the passsword (Encrypt it)
  passwordHash String
  // List of roles for the user
  // Set BUYER role as default
  roles Role[] @default([BUYER])
  // Unique profile
  // Set to optional so that a user can exist first
  profile Profile?
  // List of products that a user is selling
  products Product[]
  // List of orders that a user is buying
  orders Order[]
  // List of listings the seller has posted
  listings Listing[]
  // The date and time when a user creates an account
  createdAt DateTime @default(now())
  // The date and time when a user updates an account
  updatedAt DateTime @updatedAt
}

// Model (data table) to store information about a user's profile
model Profile {
  id                 String   @id @default(cuid()) // Unique ID for each user
  userId             String   @unique              // Link the profile to only one user (id)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)// user that made the profile
  name               String                        // Name of the profile
  location           String?                       // home base of creator. optional
  pickupInstructions String?  @db.Text             // Instructions for picking up orders. optional
                                                   // Set to optional since not every user will be a seller
  pickupTimes        DailySchedule[]               // the pickup availability schedule for each day. One array index for each day of the week                                                  
  createdAt          DateTime @default(now())      // The date and time when a profile gets created
  updatedAt          DateTime @updatedAt           // The date and time when a profile gets updated
}

//data table to store a vendors available times for a specific day
model DailySchedule {
  profileId     String                                    // id of the profile the schedule is linked to
  day           String                                    // enum to specify which day this schedule is for. TEMPORARILY SWITCHING TO STRING TO MAKE IT EASIER
  @@id (fields: [profileId, day], name: "profileDay")     // unique identifier is both the profileId and the day together
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)//reference back to Profile model 
  times         Boolean[] @default([false])               // 24 hour clock. element 0 is 00:00, element 1 is 01:00 etc.
                                                          // available pickup times are set to true.
  isOpen        Boolean   @default(false)                 // boolean to indicate whether a store is open on a given day  
}

// Model (data table) to store a product information
model Product {
  id          String  @id @default(cuid()) // Unique ID for each product
  name        String                       // Product name
  description String  @db.Text             // Product description
  price       Float   @default(0)          // Product price
  isAvailable Boolean @default(false)      // Product availability status
  isReserved  Boolean @default(false)      // Product reserved status
  stock       Int     @default(0)          // Total quantity available in stock
  listings    ProductsToListings[]         // Explicit many-to-many relation with Listing model
                                           // One product can be available in multiple listings. (e.g. tomato can be purchased
                                           // alone, or as part of a wholesale vegetable bundle)
  orderItems  OrderItem[]                  // Reference to the orders that include this product
                                           // onDelete: SetNull means that if a product is deleted,
                                           // the reference in the orders will be set to null instead of deleting the orders
  sellerId    String                       // Reference to the seller's id
  seller      User    @relation(fields: [sellerId], references: [id], onDelete: Cascade) // User making the product                     
}

//Data table to store all of a vendor's listings
model Listing {
  id             String    @id @default(cuid()) // Unique ID for each listing
  title          String                         // listing title
  description    String    @db.Text             // listing description
  products       ProductsToListings[]           // Explicit many-to-many relation with Product model
                                                // one listing can have multiple products. (e.g. wholesale vegebatle bundle)
  quantity       Int[]                          // parallel to array of products. quantity[0] is quantity of products[0] etc.
  price          Float                          // listing price
  isAvailable    Boolean   @default(false)      // bool is true only when all products' isAvailable bools are true
  sellerId       String                         // Reference to the seller's id
  seller         User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)// User making the listing
}

//join table for Product and Listing
model ProductsToListings {
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade) // Reference to Product model
  productId    String                                                                         // id of linked prodect
  listing      Listing    @relation(fields: [listingId], references: [id], onDelete: Cascade) // Reference to Listing Model
  listingId    String                                                                         //id of linked listing
  @@id ([listingId, productId])              
}

// Model (data table) to store an order information
// this data table is also used to store a cart information
// since a cart is an order with the status of CART
model Order {
  // Unique ID for each order
  id String @id @default(cuid())
  // Reference to the buyer's id
  buyerId String
  // Reference back to the User model for the buyerId
  // onDelete: Cascade means that if a user is deleted, the associated orders will also be deleted automatically
  buyer User @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  // List of items in the order
  items OrderItem[]
  // Reference to the order status
  status OrderStatus @default(CART)
  // The date and time when a user creates an order
  createdAt DateTime @default(now())
  // The date and time when a user updates an order
  updatedAt DateTime @updatedAt
}

// Model (data table) to store an order item information
model OrderItem {
  // Unique ID for each order item
  id String @id @default(cuid())
  // Reference to the order's id
  orderId String
  // Reference back to the Order model for the orderId
  // onDelete: Cascade means that if an order is deleted, the associated order items will also be deleted automatically
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Reference to the product's id
  productId String
  // Reference back to the Product model for the productId
  // onDelete: Cascade means that if a product is deleted, the associated order items will also be deleted automatically
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Quantity of the product in the order item
  quantity Int @default(1)
  // Prevent the same product from being added to the same order multiple times
  // this increases the quantity instead of creating a new order item
  @@unique([orderId, productId])
}