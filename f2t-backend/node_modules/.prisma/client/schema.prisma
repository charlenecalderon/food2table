// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Generate a typescypt/javascrypt client to import in Node.js
generator client {
  // Use the prisma client for JavaScript and Typescript
  provider = "prisma-client-js"
}

// Connection to the database with PostgreSQL
datasource db {
  // The type of the database
  provider = "postgresql"
}

//enum for days of the week
enum Day {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  NONE
}

// Define the roles the users can have
enum Role {
  // Role for general users
  USER
  // Role to manage the website
  ADMIN
}

// Define the status of the order
enum OrderStatus {
  // Order is created and being updated with items
  CART
  // Order is reserved and waiting for user to place the order
  RESERVED
  // Order is finalized and ready to be processed
  PLACED
  // Buyer has paid in person and the seller provided the products to the buyer
  COMPLETED
  // Order is cancelled by the buyer or seller
  CANCELLED
}

// Model (data table) to store login and role information
model User {
  // Unique ID for each user
  id           String    @id @default(cuid())
  // Unique email address
  email        String    @unique
  // Hashed the passsword (Encrypt it)
  passwordHash String
  // List of roles for the user
  // Set BUYER role as default
  roles        Role[]    @default([USER])
  // Unique profile
  // Set to optional so that a user can exist first
  profile      Profile?
  // List of products that a user is selling
  products     Product[]
  // List of orders that a user is buying
  orders       Order[]
  // The date and time when a user creates an account
  createdAt    DateTime  @default(now())
  // The date and time when a user updates an account
  updatedAt    DateTime  @updatedAt
}

// Model (data table) to store information about a user's profile
model Profile {
  // Unique ID for each user
  id                 String          @id @default(cuid())
  // Link the profile to only one user (id)
  userId             String          @unique
  // Reference back to the User model
  // onDelete: Cascade means that if a user is deleted, the associated profile will also be deleted automatically
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Name of the profile
  name               String
  // User location
  // Set to optional since not every user will be a seller
  location           String?
  // Instructions for picking up orders
  // Set to optional since not every user will be a seller
  pickupInstructions String?         @db.Text
  //the pickup availability schedule for each day. One array index for each day of the week
  //All parts of DailySchedule are defaulted to false, null, etc because it won't let me make pickupTimes optional
  pickupTimes        DailySchedule[]
  // The date and time when a profile gets created
  createdAt          DateTime        @default(now())
  // The date and time when a profile gets updated
  updatedAt          DateTime        @updatedAt
}

//data table to store a vendors available times for a specific day
model DailySchedule {
  // Unique ID for each daily schedule
  id        String    @id @default(cuid())
  //id of the profile the schedule is linked to
  profileId String    @unique
  //enum to specify which day this schedule is for. TEMPORARILY SWITCHING TO STRING TO MAKE IT EASIER
  day       String
  //reference back to Profile model
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  //array to hold booleans indicated which 15 minute increments of the day are available for pickups
  times     Boolean[] @default([false])
  //boolean to indicate whether I store is open on a given day
  isOpen    Boolean   @default(false)

  //unique identifier so that the user doesn't have to know the id of the day they're looking for.
  //can be found using the day and the profile id
  @@unique(fields: [profileId, day], name: "profileDay")
}

// Model (data table) to store a product information
model Product {
  // Unique ID for each product
  id          String      @id @default(cuid())
  // Product name
  name        String
  // Product description
  // @db.Text allows for longer text than the default String type
  description String      @db.Text
  //Product availability status
  isAvailable Boolean     @default(false)
  // Product reserved status
  isReserved  Boolean     @default(false)
  // Product price
  price       Float
  // Total quantity available in stock
  stock       Int         @default(0)
  // Reference to the seller's id
  sellerId    String
  // Reference back to the User model for the sellerId
  // onDelete: Cascade means that if a user is deleted, the associated products will also be deleted automatically
  seller      User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  // Reference to the orders that include this product
  // onDelete: SetNull means that if a product is deleted, the reference in the orders will be set to null instead of deleting the orders
  orderItems  OrderItem[]
  // The date and time when a user creates a product
  createdAt   DateTime    @default(now())
  // The date and time when a user updates a product
  updatedAt   DateTime    @updatedAt
}

// Model (data table) to store an order information
model Order {
  // Unique ID for each order
  id        String      @id @default(cuid())
  // Reference to the buyer's id
  buyerId   String
  // Reference back to the User model for the buyerId
  // onDelete: Cascade means that if a user is deleted, the associated orders will also be deleted automatically
  buyer     User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  // List of items in the order
  items     OrderItem[]
  // Reference to the order status
  status    OrderStatus @default(CART)
  // The date and time when a user creates an order
  createdAt DateTime    @default(now())
  // The date and time when a user updates an order
  updatedAt DateTime    @updatedAt
}

// Model (data table) to store an order item information
model OrderItem {
  // Unique ID for each order item
  id        String  @id @default(cuid())
  // Reference to the order's id
  orderId   String
  // Reference back to the Order model for the orderId
  // onDelete: Cascade means that if an order is deleted, the associated order items will also be deleted automatically
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Reference to the product's id
  productId String
  // Reference back to the Product model for the productId
  // onDelete: Cascade means that if a product is deleted, the associated order items will also be deleted automatically
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Quantity of the product in the order item
  quantity  Int     @default(1)

  // Prevent the same product from being added to the same order multiple times
  // this increases the quantity instead of creating a new order item
  @@unique([orderId, productId])
}
